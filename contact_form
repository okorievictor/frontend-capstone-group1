<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Planetary Science Contact Form</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family: Arial, Helvetica, sans-serif;
    }

    body{
      background:#f3f3f3;
      color:#111827;
    }

    .contact-section{
      width:100%;
      padding:60px 20px 0;
      display:flex;
      justify-content:center;
    }

    .container{
      width:100%;
      max-width:700px;
    }

    .heading{
      text-align:center;
      margin-bottom:45px;
    }

    .heading h1{
      font-size:52px;
      line-height:1.2;
      color:#1F4FB5;
      font-weight:700;
      margin-bottom:25px;
    }

    .heading p{
      font-size:22px;
      line-height:1.7;
      color:#1f2937;
      max-width:650px;
      margin:auto;
    }

    form{
      width:100%;
    }

    .form-group{
      margin-bottom:38px;
    }

    label{
      display:block;
      font-size:24px;
      font-weight:700;
      margin-bottom:18px;
      color:#111827;
    }

    label span{
      color:#E11D48;
    }

    input,
    textarea{
      width:100%;
      border:2px solid #d1d5db;
      border-radius:18px;
      padding:28px 28px;
      font-size:22px;
      outline:none;
      background:#f8f8f8;
      color:#111827;
      transition:0.3s ease;
    }

    input::placeholder,
    textarea::placeholder{
      color:#6b7280;
    }

    input:focus,
    textarea:focus{
      border-color:#1F4FB5;
      background:#fff;
    }

    textarea{
      resize:none;
      height:280px;
    }

    .character{
      margin-top:14px;
      font-size:20px;
      color:#555;
    }

    .submit-btn{
      width:100%;
      height:92px;
      border:none;
      border-radius:18px;
      background:#1F4FB5;
      color:#fff;
      font-size:30px;
      font-weight:700;
      cursor:pointer;
      transition:0.3s ease;
      display:flex;
      align-items:center;
      justify-content:center;
      gap:18px;
    }

    .submit-btn:hover{
      background:#173f95;
    }

    .footer{
      background:#03114D;
      margin-top:80px;
      padding:60px 20px;
      color:#fff;
    }

    .footer-container{
      max-width:700px;
      margin:auto;
    }

    .footer h2{
      font-size:40px;
      margin-bottom:50px;
    }

    .footer p{
      font-size:24px;
      line-height:1.8;
    }

    .line{
      width:100%;
      height:1px;
      background:rgba(255,255,255,0.4);
      margin:40px 0;
    }

    .brand{
      margin-top:35px;
      font-size:30px;
      font-weight:500;
    }

    /* RESPONSIVE DESIGN */

    @media (max-width:768px){

      .contact-section{
        padding:45px 18px 0;
      }

      .heading h1{
        font-size:34px;
      }

      .heading p{
        font-size:18px;
      }

      label{
        font-size:18px;
      }

      input,
      textarea{
        font-size:18px;
        padding:22px 20px;
        border-radius:14px;
      }

      textarea{
        height:220px;
      }

      .submit-btn{
        height:72px;
        font-size:24px;
        border-radius:14px;
      }

      .footer{
        padding:45px 18px;
      }

      .footer h2{
        font-size:28px;
      }

      .footer p{
        font-size:18px;
      }

      .brand{
        font-size:24px;
      }
    }

  </style>
</head>

<body>

  <section class="contact-section">

    <div class="container">

      <div class="heading">
        <h1>
          Have Questions About <br>
          Planetary Science?
        </h1>

        <p>
          Interested in learning more about space,
          astronomy, or how planetary data is collected
          and analyzed? Reach out and we’ll get back to
          you.
        </p>
      </div>

      <form>

        <div class="form-group">
          <label>
            Full Name<span>*</span>
          </label>

          <input 
            type="text" 
            placeholder="Full name"
            required
          />
        </div>

        <div class="form-group">
          <label>
            Email<span>*</span>
          </label>

          <input 
            type="email" 
            placeholder="example@example.com"
            required
          />
        </div>

        <div class="form-group">
          <label>
            Phone Number<span>*</span>
          </label>

          <input 
            type="tel" 
            placeholder="Please enter a valid phone number."
            required
          />
        </div>

        <div class="form-group">
          <label>
            Message<span>*</span>
          </label>

          <textarea 
            placeholder="Enter your message"
            maxlength="100"
            required
          ></textarea>

          <p class="character">100 characters</p>
        </div>

        <button type="submit" class="submit-btn">
          Submit
          <span>›</span>
        </button>

      </form>

    </div>
 
</section>

</body>
</html>